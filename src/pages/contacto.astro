---
import Layout from '../layouts/Layout.astro';
import { url } from '../utils/links';
---

<Layout title="Contacto | Perito Médico Barcelona" description="Solicite una valoración gratuita de su caso. Formulario de contacto para peritaje médico en Barcelona.">
  <!-- Hero -->
  <section class="bg-primary-950 py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <span class="text-accent-400 font-semibold text-sm tracking-wider uppercase">Contacto</span>
        <h1 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold text-white mt-3 mb-5">
          Solicite su valoración gratuita
        </h1>
        <p class="text-lg text-primary-200">
          Rellene el formulario con los datos de su caso y le responderemos en menos de 24 horas. La primera valoración es gratuita y sin compromiso.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-16">
        <!-- Formulario -->
        <div class="lg:col-span-2">
          <form id="contact-form" action="https://api.web3forms.com/submit" method="POST" class="space-y-6">
            <input type="hidden" name="access_key" value="ff6a4d07-d9d3-4092-9bcf-b9aeca9c60cd" />
            <input type="hidden" name="subject" value="Nueva consulta desde peritomedicobarcelona.es" />
            <input type="hidden" name="redirect" value="https://alexmc14.github.io/peritomedicobarcelona/gracias" />
            <input type="checkbox" name="botcheck" class="hidden" style="display:none" />
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="nombre" class="block text-sm font-medium text-gray-700 mb-2">Nombre completo *</label>
                <input type="text" id="nombre" name="nombre" required
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all text-sm"
                  placeholder="Su nombre completo" />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email *</label>
                <input type="email" id="email" name="email" required
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all text-sm"
                  placeholder="su@email.com" />
              </div>
            </div>

            <div>
              <label for="telefono" class="block text-sm font-medium text-gray-700 mb-2">Teléfono *</label>
              <input type="tel" id="telefono" name="telefono" required
                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all text-sm"
                placeholder="612 345 678" />
            </div>

            <div class="flex items-start gap-3">
              <input type="checkbox" id="privacidad" name="privacidad" required
                class="mt-1 w-4 h-4 text-primary-600 border-gray-300 rounded focus:ring-primary-500" />
              <label for="privacidad" class="text-xs text-gray-500">
                He leído y acepto la <a href={url('/politica-privacidad')} class="text-primary-700 underline">Política de Privacidad</a>. Sus datos serán tratados con total confidencialidad y no serán cedidos a terceros.
              </label>
            </div>

            <button type="submit"
              class="w-full sm:w-auto px-8 py-4 bg-accent-500 hover:bg-accent-600 text-white font-semibold rounded-xl transition-all shadow-lg shadow-accent-500/25 hover:shadow-accent-500/40 text-base">
              Enviar consulta
              <svg class="w-5 h-5 ml-2 inline-block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </button>
          </form>
        </div>

        <!-- Sidebar -->
        <div class="space-y-8">
          <div class="bg-primary-50 rounded-2xl p-8">
            <h3 class="font-heading text-lg font-semibold text-primary-900 mb-4">Valoración gratuita</h3>
            <p class="text-sm text-gray-600 leading-relaxed mb-4">
              Analizamos su caso sin coste ni compromiso. Le indicaremos las posibilidades médico-legales y el mejor enfoque para su situación.
            </p>
            <div class="space-y-3">
              <div class="flex items-center gap-3 text-sm text-gray-700">
                <svg class="w-5 h-5 text-accent-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                Respuesta en menos de 24h
              </div>
              <div class="flex items-center gap-3 text-sm text-gray-700">
                <svg class="w-5 h-5 text-accent-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                Confidencialidad absoluta
              </div>
              <div class="flex items-center gap-3 text-sm text-gray-700">
                <svg class="w-5 h-5 text-accent-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Sin compromiso
              </div>
            </div>
          </div>

          <div class="bg-white rounded-2xl p-8 border border-gray-100">
            <h3 class="font-heading text-lg font-semibold text-primary-900 mb-4">¿Es usted abogado/a?</h3>
            <p class="text-sm text-gray-600 leading-relaxed mb-4">
              Disponemos de un servicio especializado para despachos profesionales con condiciones adaptadas.
            </p>
            <a href={url('/para-abogados/asesoramiento-tecnico')} class="inline-flex items-center text-sm font-medium text-primary-700 hover:text-accent-600 transition-colors">
              Ver servicios para abogados
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/HeroSection.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CTASection from '../components/CTASection.astro';
import { url } from '../utils/links';

const servicios = [
  {
    title: 'Informes Periciales Médicos',
    description: 'Elaboración de informes periciales médicos detallados y fundamentados para procesos judiciales y extrajudiciales.',
    href: url('/servicios/informes-periciales-medicos'),
  },
  {
    title: 'Negligencia Médica',
    description: 'Evaluación experta de posibles casos de mala praxis médica con análisis de la lex artis y nexo causal.',
    href: url('/servicios/negligencia-medica'),
  },
  {
    title: 'Valoración del Daño Corporal',
    description: 'Cuantificación médico-legal de las lesiones y secuelas conforme al baremo vigente.',
    href: url('/servicios/valoracion-dano-corporal'),
  },
  {
    title: 'Incapacidad Laboral',
    description: 'Valoración de la capacidad funcional para procesos de incapacidad permanente en cualquier grado.',
    href: url('/servicios/incapacidad-laboral'),
  },
  {
    title: 'Impugnación de Alta Médica',
    description: 'Análisis médico-pericial para impugnar altas médicas indebidas ante el INSS o Mutuas.',
    href: url('/servicios/impugnacion-alta-medica'),
  },
  {
    title: 'Discapacidad',
    description: 'Valoración del grado de discapacidad y asesoramiento para su reconocimiento administrativo.',
    href: url('/servicios/discapacidad'),
  },
  {
    title: 'Curatela y Medidas de Apoyo',
    description: 'Informes periciales para procedimientos de determinación de capacidad y medidas de apoyo.',
    href: url('/servicios/curatela-medidas-apoyo'),
  },
  {
    title: 'Determinación de Contingencia',
    description: 'Análisis pericial para determinar el origen laboral o común de una patología.',
    href: url('/servicios/determinacion-contingencia'),
  },
  {
    title: 'Segunda Opinión Médico-Legal',
    description: 'Revisión independiente de informes periciales existentes con análisis crítico y fundamentado.',
    href: url('/servicios/segunda-opinion-medico-legal'),
  },
  {
    title: 'Estudio de Viabilidad del Caso',
    description: 'Análisis preliminar gratuito para evaluar las posibilidades médico-legales de su caso.',
    href: url('/servicios/estudio-viabilidad'),
  },
];

const proceso = [
  {
    step: '01',
    title: 'Contacto inicial',
    description: 'Nos envía su caso a través del formulario. Realizamos una primera valoración gratuita.',
  },
  {
    step: '02',
    title: 'Estudio del caso',
    description: 'Analizamos toda la documentación médica y legal para definir la estrategia pericial.',
  },
  {
    step: '03',
    title: 'Exploración médica',
    description: 'Si es necesario, realizamos una exploración médica presencial en Barcelona.',
  },
  {
    step: '04',
    title: 'Informe pericial',
    description: 'Elaboramos un informe pericial médico riguroso, claro y fundamentado.',
  },
];

const faqs = [
  {
    question: '¿Qué es un informe pericial médico?',
    answer: 'Un informe pericial médico es un documento elaborado por un médico especialista que analiza y valora las lesiones, secuelas o situación clínica de un paciente con finalidad jurídica. Es una prueba fundamental en procesos judiciales.',
  },
  {
    question: '¿Cuánto tarda la elaboración de un informe pericial?',
    answer: 'El plazo habitual es de 7 a 15 días desde la recepción de toda la documentación médica. En casos urgentes, podemos reducir este plazo. La primera valoración del caso se realiza en 24-48 horas.',
  },
  {
    question: '¿La primera consulta es gratuita?',
    answer: 'Sí. Realizamos un estudio de viabilidad gratuito y sin compromiso para evaluar las posibilidades médico-legales de su caso antes de iniciar cualquier trabajo.',
  },
  {
    question: '¿En qué zonas trabajan?',
    answer: 'Nuestro centro está en Barcelona, pero realizamos informes periciales para toda Cataluña y el resto de España. Las exploraciones presenciales se realizan en Barcelona.',
  },
  {
    question: '¿Pueden ratificar el informe en juicio?',
    answer: 'Sí. Nuestros peritos médicos realizan la ratificación judicial del informe pericial, defendiendo las conclusiones ante el juez y las partes en sala.',
  },
  {
    question: '¿Trabajan con abogados?',
    answer: 'Sí. Ofrecemos un servicio especializado para despachos de abogados que incluye asesoramiento técnico, revisión de informes de parte contraria y contrainformes periciales.',
  },
];
---

<Layout title="Perito Médico Barcelona | Informes Periciales Médicos">
  <HeroSection />

  <!-- Servicios -->
  <section class="py-20 lg:py-28 bg-gray-50/50" id="servicios">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <span class="text-accent-600 font-semibold text-sm tracking-wider uppercase">Nuestros Servicios</span>
        <h2 class="font-heading text-3xl sm:text-4xl font-bold text-primary-900 mt-3 mb-5">
          Servicios de Peritaje Médico
        </h2>
        <p class="text-gray-500 max-w-2xl mx-auto text-lg">
          Ofrecemos un servicio integral de peritaje médico adaptado a las necesidades de cada caso.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {servicios.map(servicio => (
          <ServiceCard
            title={servicio.title}
            description={servicio.description}
            href={servicio.href}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Cómo trabajamos -->
  <section class="py-20 lg:py-28" id="como-trabajamos">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <span class="text-accent-600 font-semibold text-sm tracking-wider uppercase">Proceso</span>
        <h2 class="font-heading text-3xl sm:text-4xl font-bold text-primary-900 mt-3 mb-5">
          Cómo trabajamos
        </h2>
        <p class="text-gray-500 max-w-2xl mx-auto text-lg">
          Un proceso claro, transparente y enfocado en obtener el mejor resultado para su caso.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {proceso.map(p => (
          <div class="text-center">
            <div class="w-16 h-16 bg-primary-900 rounded-2xl flex items-center justify-center mx-auto mb-5">
              <span class="text-accent-300 font-heading font-bold text-xl">{p.step}</span>
            </div>
            <h3 class="font-heading text-lg font-semibold text-primary-900 mb-3">{p.title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{p.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Sobre Nosotros -->
  <section class="py-20 lg:py-28 bg-gray-50/50" id="sobre-nosotros">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="text-accent-600 font-semibold text-sm tracking-wider uppercase">Sobre Nosotros</span>
          <h2 class="font-heading text-3xl sm:text-4xl font-bold text-primary-900 mt-3 mb-6">
            Experiencia y rigor al servicio de la justicia
          </h2>
          <div class="space-y-5 text-gray-600 leading-relaxed">
            <p>
              Somos un equipo de médicos peritos especializados en medicina legal y forense, con amplia experiencia en la elaboración de informes periciales médicos para procesos judiciales y extrajudiciales.
            </p>
            <p>
              Nuestra misión es proporcionar informes periciales rigurosos, objetivos e independientes que contribuyan a la correcta administración de la justicia y a la defensa de los derechos de nuestros clientes.
            </p>
          </div>

          <div class="grid grid-cols-2 gap-6 mt-10">
            <div class="bg-white rounded-xl p-5 border border-gray-100">
              <div class="font-heading text-3xl font-bold text-primary-900">+500</div>
              <div class="text-sm text-gray-500 mt-1">Informes periciales</div>
            </div>
            <div class="bg-white rounded-xl p-5 border border-gray-100">
              <div class="font-heading text-3xl font-bold text-primary-900">+200</div>
              <div class="text-sm text-gray-500 mt-1">Ratificaciones judiciales</div>
            </div>
          </div>
        </div>

        <div class="bg-primary-900 rounded-3xl p-10 text-white relative overflow-hidden">
          <div class="absolute top-0 right-0 w-64 h-64 bg-accent-400/10 rounded-full blur-3xl translate-x-1/2 -translate-y-1/2"></div>
          <div class="relative space-y-8">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-accent-500/20 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-accent-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
              </div>
              <div>
                <h3 class="font-semibold text-lg mb-1">Independencia</h3>
                <p class="text-primary-200 text-sm">Informes objetivos sin conflictos de interés con aseguradoras ni entidades.</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-accent-500/20 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-accent-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>
              </div>
              <div>
                <h3 class="font-semibold text-lg mb-1">Rigor científico</h3>
                <p class="text-primary-200 text-sm">Metodología basada en la evidencia médica y los protocolos de valoración vigentes.</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-accent-500/20 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-accent-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" /></svg>
              </div>
              <div>
                <h3 class="font-semibold text-lg mb-1">Experiencia judicial</h3>
                <p class="text-primary-200 text-sm">Amplia experiencia en ratificaciones judiciales en juzgados de toda España.</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-accent-500/20 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-accent-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
              </div>
              <div>
                <h3 class="font-semibold text-lg mb-1">Equipo multidisciplinar</h3>
                <p class="text-primary-200 text-sm">Red de especialistas en todas las áreas médicas para cubrir cualquier caso.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Para Abogados -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-primary-50 rounded-3xl p-10 lg:p-16">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <span class="text-accent-600 font-semibold text-sm tracking-wider uppercase">Para Profesionales</span>
            <h2 class="font-heading text-3xl sm:text-4xl font-bold text-primary-900 mt-3 mb-6">
              Servicio para Abogados
            </h2>
            <p class="text-gray-600 leading-relaxed mb-8">
              Colaboramos con despachos de abogados ofreciendo un servicio integral de peritaje médico. Asesoramiento técnico, revisión de informes de parte contraria, contrainformes y ratificación judicial.
            </p>
            <ul class="space-y-4 mb-8">
              <li class="flex items-center gap-3 text-gray-700">
                <svg class="w-5 h-5 text-accent-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Asesoramiento técnico previo al procedimiento
              </li>
              <li class="flex items-center gap-3 text-gray-700">
                <svg class="w-5 h-5 text-accent-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Ratificación judicial en sala
              </li>
              <li class="flex items-center gap-3 text-gray-700">
                <svg class="w-5 h-5 text-accent-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Revisión de informes periciales de parte contraria
              </li>
              <li class="flex items-center gap-3 text-gray-700">
                <svg class="w-5 h-5 text-accent-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Contrainformes periciales fundamentados
              </li>
            </ul>
            <a href={url('/para-abogados/asesoramiento-tecnico')} class="inline-flex items-center px-6 py-3 bg-primary-900 hover:bg-primary-800 text-white font-semibold rounded-xl transition-colors text-sm">
              Ver servicios para abogados
              <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </a>
          </div>
          <div class="hidden lg:flex items-center justify-center">
            <div class="w-72 h-72 bg-primary-100 rounded-3xl flex items-center justify-center">
              <svg class="w-32 h-32 text-primary-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="0.75" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />
              </svg>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 lg:py-28 bg-gray-50/50" id="faq">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <span class="text-accent-600 font-semibold text-sm tracking-wider uppercase">FAQ</span>
        <h2 class="font-heading text-3xl sm:text-4xl font-bold text-primary-900 mt-3 mb-5">
          Preguntas Frecuentes
        </h2>
      </div>

      <div class="space-y-4">
        {faqs.map(faq => (
          <details class="group bg-white rounded-xl border border-gray-100 overflow-hidden">
            <summary class="flex justify-between items-center cursor-pointer px-7 py-5 text-primary-900 font-medium hover:bg-gray-50 transition-colors">
              <span class="text-left pr-4">{faq.question}</span>
              <svg class="w-5 h-5 text-gray-400 flex-shrink-0 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="px-7 pb-5 text-gray-600 text-sm leading-relaxed">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>

    <!-- FAQ Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.answer,
        }
      }))
    })} />
  </section>

  <CTASection />
</Layout>

---
import Layout from '../layouts/Layout.astro';
import CTASection from '../components/CTASection.astro';
import { url } from '../utils/links';

const servicios = [
  { name: 'Negligencia Médica', href: '/servicios/negligencia-medica', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
  { name: 'Valoración Daño Corporal', href: '/servicios/valoracion-dano-corporal', icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z' },
  { name: 'Incapacidad Laboral', href: '/servicios/incapacidad-laboral', icon: 'M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z' },
  { name: 'Accidentes de Tráfico', href: '/accidentes-de-trafico', icon: 'M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z' },
  { name: 'Seguridad Social / INSS', href: '/servicios/perito-seguridad-social', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2' },
  { name: 'Accidente de Trabajo', href: '/servicios/accidente-trabajo', icon: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z' },
];

const faqs = [
  {
    question: '¿La consulta es realmente gratuita?',
    answer: 'Sí. La consulta inicial, el asesoramiento sobre su caso y la valoración de la viabilidad médico-legal son completamente gratuitas y sin compromiso. Solo tiene coste la elaboración del informe pericial completo, que se presupuesta antes de iniciar cualquier trabajo.',
  },
  {
    question: '¿Qué información necesito para la consulta?',
    answer: 'Con una descripción básica del caso es suficiente para empezar: qué ocurrió, cuándo y qué consecuencias médicas ha tenido. Si dispone de informes médicos, parte de accidente o documentación clínica, puede adjuntarlos, pero no es imprescindible para la primera valoración.',
  },
  {
    question: '¿Puedo consultar por teléfono o solo por escrito?',
    answer: 'Puede contactarnos tanto por teléfono como a través del formulario de contacto o por correo electrónico. Para casos complejos, muchas veces una llamada es la forma más rápida de hacer una primera valoración.',
  },
  {
    question: '¿En cuánto tiempo recibo respuesta?',
    answer: 'Nos comprometemos a responder en menos de 24 horas laborables. En muchos casos la respuesta es el mismo día. Si tiene un juicio inminente o una fecha límite, indíquenoslo y lo trataremos de forma urgente.',
  },
  {
    question: '¿Pueden asesorarme aunque no sea de Barcelona?',
    answer: 'Sí. Realizamos consultas y elaboramos informes periciales para toda España. La exploración médica presencial se realiza en Barcelona, pero la consulta gratuita, el asesoramiento y la elaboración del informe pueden hacerse a distancia para clientes de toda Cataluña y el resto del país.',
  },
];
---

<Layout
  title="Consulta Gratuita con Perito Médico Barcelona | Sin Compromiso"
  description="Primera consulta gratuita con perito médico en Barcelona. Asesoramiento médico-legal sin coste para cualquier tipo de caso: daño corporal, negligencia, incapacidad, accidentes. Respuesta en 24 h."
>
  <!-- Hero -->
  <section class="bg-primary-950 py-16 lg:py-24 relative overflow-hidden">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.4&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block bg-accent-500 text-white text-sm font-bold px-4 py-2 rounded-full mb-6 tracking-wider uppercase">
        Primera Consulta Gratuita
      </span>
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">
        Consulta <span class="text-accent-300">Gratuita</span> con Perito Médico en Barcelona
      </h1>
      <p class="text-xl text-primary-200 leading-relaxed mb-10 max-w-2xl mx-auto">
        Le asesoramos sin coste sobre cualquier caso médico-legal. Negligencia médica, accidentes, incapacidad permanente, daño corporal... Cuéntenos su caso y le respondemos en menos de 24 horas.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={url('/contacto')} class="inline-flex items-center justify-center px-10 py-5 bg-accent-500 hover:bg-accent-600 text-white font-bold rounded-xl transition-all shadow-lg shadow-accent-500/25 text-lg">
          Pedir consulta gratuita
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>
      <p class="mt-4 text-sm text-primary-400">Sin coste · Sin compromiso · Respuesta en menos de 24 h</p>
    </div>
  </section>

  <!-- Qué incluye -->
  <section class="py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="font-heading text-3xl font-bold text-primary-900 mb-4">¿Qué incluye la consulta gratuita?</h2>
        <p class="text-gray-500 max-w-xl mx-auto">La consulta gratuita es una valoración real de su caso por un perito médico especializado, no una simple respuesta automática.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        <div class="bg-gray-50 rounded-2xl p-7 text-center">
          <div class="w-14 h-14 bg-primary-900 rounded-xl flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-accent-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="font-heading text-lg font-semibold text-primary-900 mb-3">Análisis del caso</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Un perito médico analiza la situación que nos describe y evalúa si existe base médico-legal para una reclamación.</p>
        </div>
        <div class="bg-gray-50 rounded-2xl p-7 text-center">
          <div class="w-14 h-14 bg-primary-900 rounded-xl flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-accent-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="font-heading text-lg font-semibold text-primary-900 mb-3">Estimación de indemnización</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Le damos una estimación orientativa de la cuantía que podría corresponderle según el baremo y las circunstancias del caso.</p>
        </div>
        <div class="bg-gray-50 rounded-2xl p-7 text-center">
          <div class="w-14 h-14 bg-primary-900 rounded-xl flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-accent-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
          </div>
          <h3 class="font-heading text-lg font-semibold text-primary-900 mb-3">Asesoramiento honesto</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Le decimos con honestidad si el caso tiene posibilidades reales. Si no las tiene, también se lo decimos, sin hacerle perder tiempo ni dinero.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Casos en los que podemos ayudarle -->
  <section class="py-16 lg:py-20 bg-gray-50/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="font-heading text-3xl font-bold text-primary-900 mb-4">¿En qué casos puede consultarnos gratis?</h2>
        <p class="text-gray-500 max-w-xl mx-auto">Ofrecemos consulta gratuita para cualquier caso que requiera peritaje médico.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 max-w-5xl mx-auto">
        {servicios.map(s => (
          <a href={url(s.href)} class="bg-white rounded-xl p-6 border border-gray-100 hover:shadow-md hover:border-primary-100 transition-all flex items-start gap-4">
            <div class="w-10 h-10 bg-primary-50 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={s.icon} /></svg>
            </div>
            <div>
              <span class="font-semibold text-primary-900 text-sm">{s.name}</span>
              <p class="text-xs text-gray-400 mt-0.5">Ver más →</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 lg:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-2xl font-bold text-primary-900 mb-8 text-center">Preguntas sobre la consulta gratuita</h2>
      <div class="space-y-3">
        {faqs.map(faq => (
          <details class="group bg-white rounded-xl border border-gray-100 overflow-hidden">
            <summary class="flex justify-between items-center cursor-pointer px-7 py-5 text-primary-900 font-medium hover:bg-gray-50 transition-colors">
              <span class="text-left pr-4 text-sm">{faq.question}</span>
              <svg class="w-5 h-5 text-gray-400 flex-shrink-0 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="px-7 pb-5 text-gray-600 text-sm leading-relaxed">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.question,
      "acceptedAnswer": { "@type": "Answer", "text": f.answer }
    }))
  })} />

  <CTASection title="Cuéntenos su caso ahora, es gratis" subtitle="Sin coste, sin compromiso. Le responderemos con una valoración honesta en menos de 24 horas." />
</Layout>

import ServiceLayout from '../../layouts/ServiceLayout.astro';
---

<ServiceLayout
  title="Perito Médico en Traumatología"
  pageTitle="Perito Médico en Traumatología Barcelona | Fracturas y Secuelas"
  description="Perito médico especializado en traumatología en Barcelona. Valoración pericial de fracturas, esguinces, lesiones articulares y secuelas de accidentes. Consulta gratuita."
  intro="Elaboramos informes periciales médicos especializados en traumatología para procesos judiciales y reclamaciones de indemnización en Barcelona. Valoramos fracturas, esguinces, lesiones articulares, hernias discales postraumáticas y cualquier secuela del aparato locomotor derivada de accidentes o agresiones."
  whatWeDo="Nuestro peritaje traumatológico consiste en el análisis completo de las lesiones sufridas, las pruebas diagnósticas (radiografías, TAC, resonancias magnéticas), el tratamiento recibido y el estado actual del paciente. Aplicamos el baremo de valoración del daño corporal establecido por la Ley 35/2015 para cuantificar con precisión los días de incapacidad temporal, las secuelas permanentes y su traducción económica. El resultado es un informe pericial sólido, riguroso y defendible en juicio, orientado a que el paciente reciba la indemnización que le corresponde."
  steps={[
    { title: 'Revisión de la documentación médica', description: 'Analizamos informes médicos, pruebas de imagen (radiografías, TAC, RMN) y el historial clínico completo para establecer la cronología lesional y documentar las lesiones iniciales.' },
    { title: 'Exploración médica presencial', description: 'Realizamos una exploración física para evaluar el estado actual del paciente, la movilidad articular, la fuerza muscular y las limitaciones funcionales reales que pueden no quedar reflejadas en los informes previos.' },
    { title: 'Valoración y aplicación del baremo', description: 'Aplicamos el Sistema de Valoración de Daños Personales (Ley 35/2015) para cuantificar los días de incapacidad temporal, las secuelas permanentes en puntos y el perjuicio estético si corresponde.' },
    { title: 'Informe pericial traumatológico', description: 'Elaboramos un informe detallado con la descripción lesional, la evolución, las secuelas permanentes, su cuantificación económica y las conclusiones claras para el proceso judicial o la reclamación extrajudicial.' },
  ]}
  faqs={[
    { question: '¿Qué lesiones traumatológicas pueden ser objeto de peritaje médico?', answer: 'Cualquier lesión del aparato locomotor: fracturas óseas, esguinces, luxaciones, hernias discales postraumáticas, lesiones de menisco, roturas del manguito rotador, traumatismos de columna, lesiones del pie y tobillo, etc. Tanto si el origen es un accidente de tráfico, laboral, caída o agresión.' },
    { question: '¿Cómo se valoran las secuelas traumatológicas según el baremo?', answer: 'Las secuelas se cuantifican en puntos según las tablas del Sistema de Valoración de Daños Personales (Ley 35/2015). Cada punto equivale a una cuantía económica que varía en función de la edad del perjudicado. El informe pericial detalla la secuela, su puntuación y la indemnización que corresponde.' },
    { question: '¿Es imprescindible la exploración médica presencial?', answer: 'En la mayoría de casos sí, ya que permite evaluar la movilidad articular real, la fuerza muscular, los signos exploratorios específicos y las limitaciones funcionales que no siempre quedan documentadas en los informes del médico tratante.' },
    { question: '¿Este informe pericial sirve para un juicio por accidente de tráfico?', answer: 'Sí. El informe pericial traumatológico es una prueba esencial en cualquier reclamación por accidente de tráfico, accidente laboral o agresión física con secuelas. Nuestros peritos ratifican el informe en sala cuando es necesario.' },
    { question: '¿Pueden valorar el síndrome de latigazo cervical?', answer: 'Sí. El síndrome del latigazo cervical (SLC) es la patología más frecuente en accidentes de tráfico. Valoramos la lesión inicial, el tratamiento recibido, el tiempo de curación y las secuelas cervicales conforme al baremo vigente, con especial atención a las escalas funcionales validadas.' },
  ]}
/>

---
import Layout from '../layouts/Layout.astro';
import CTASection from '../components/CTASection.astro';
import { url } from '../utils/links';

const situaciones = [
  'El centro EVO le ha denegado el reconocimiento de discapacidad',
  'Le han reconocido un grado inferior al que considera que le corresponde',
  'Quiere revisar su grado porque su estado de salud ha empeorado',
  'Necesita alcanzar el 33% para acceder a beneficios fiscales o laborales',
  'Necesita alcanzar el 65% para determinadas prestaciones o ayudas',
  'Tiene varias patologías que juntas no se han valorado en su conjunto',
];

const faqs = [
  {
    question: '¿La valoración es realmente gratuita y sin compromiso?',
    answer: 'Sí. El análisis inicial de su expediente y una estimación orientativa del grado de discapacidad que podría corresponderle son completamente gratuitos. Solo tiene coste la elaboración del informe pericial completo, que se presupuesta antes de empezar y solo si usted decide contratarlo.',
  },
  {
    question: '¿Qué documentos necesito para la valoración gratuita?',
    answer: 'Lo más útil es la resolución del centro EVO (si ya tiene una), sus informes médicos de especialistas y cualquier prueba diagnóstica relevante. Si no dispone de toda la documentación, puede consultarnos igualmente y le orientamos sobre cómo obtenerla.',
  },
  {
    question: '¿Cuánto tarda el reconocimiento del grado de discapacidad?',
    answer: 'El plazo administrativo para resolver una solicitud de discapacidad es de tres meses, aunque en la práctica suele tardar más debido a la carga de los centros EVO. Si ya ha recibido una resolución y no está de acuerdo, es importante no dejar pasar el plazo para recurrir.',
  },
  {
    question: '¿Puedo recurrir si me han denegado la discapacidad?',
    answer: 'Sí. Contra la resolución del centro EVO cabe reclamación previa y, si esta se desestima, demanda ante el Juzgado de lo Social. Un informe pericial que acredite con criterios técnicos y los baremos del Real Decreto 888/2022 que su grado real es superior al reconocido es la prueba principal en ambas vías.',
  },
  {
    question: '¿Merece la pena reclamar o pedir la revisión del grado?',
    answer: 'En muchos casos sí, especialmente si el reconocimiento le da acceso a un umbral relevante (33% o 65%) que actualmente no alcanza. En la valoración gratuita le damos una opinión honesta: si vemos que el caso tiene pocas posibilidades, se lo decimos igual, sin coste ni compromiso.',
  },
];
---

<Layout
  title="Valoración Gratuita del Grado de Discapacidad Barcelona | Perito Médico"
  description="Valoración gratuita y sin compromiso de su grado de discapacidad en Barcelona. Un perito médico analiza su expediente y le orienta sobre si merece la pena reclamar o recurrir."
>
  <!-- Hero -->
  <section class="bg-primary-950 py-16 lg:py-24 relative overflow-hidden">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.4&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block bg-accent-500 text-white text-sm font-bold px-4 py-2 rounded-full mb-6 tracking-wider uppercase">
        Valoración 100% Gratuita
      </span>
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">
        Valoración Gratuita de su <span class="text-accent-300">Grado de Discapacidad</span>
      </h1>
      <p class="text-xl text-primary-200 leading-relaxed mb-10 max-w-2xl mx-auto">
        ¿Le han denegado la discapacidad o no está de acuerdo con el grado reconocido? Un perito médico analiza su expediente sin coste y le dice, con honestidad, si merece la pena reclamar.
      </p>
      <a href={url('/contacto')} class="inline-flex items-center px-10 py-5 bg-accent-500 hover:bg-accent-600 text-white font-bold rounded-xl transition-all shadow-lg shadow-accent-500/25 text-lg">
        Solicitar valoración gratuita
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
      <p class="mt-4 text-sm text-primary-400">Sin coste · Sin compromiso · Respuesta en menos de 24 h</p>
    </div>
  </section>

  <!-- ¿Se encuentra en esta situación? -->
  <section class="py-16 lg:py-20 bg-gray-50/50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-2xl font-bold text-primary-900 mb-4 text-center">¿Le podemos ayudar en alguno de estos casos?</h2>
      <p class="text-gray-500 text-center mb-10 max-w-xl mx-auto">La valoración gratuita le aclara si su caso tiene base para reclamar, revisar o recurrir.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {situaciones.map(s => (
          <div class="flex items-start gap-3 bg-white rounded-xl p-5 border border-gray-100">
            <div class="w-6 h-6 bg-accent-100 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-3.5 h-3.5 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
            </div>
            <span class="text-sm text-gray-700 leading-relaxed">{s}</span>
          </div>
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href={url('/contacto')} class="inline-flex items-center px-8 py-4 bg-primary-900 hover:bg-primary-800 text-white font-semibold rounded-xl transition-colors text-sm">
          Me identifico con esto, quiero consultarlo gratis
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Qué incluye -->
  <section class="py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-2xl font-bold text-primary-900 mb-12 text-center">¿Qué incluye la valoración gratuita?</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <div class="text-center">
          <div class="w-14 h-14 bg-primary-900 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <span class="text-accent-300 font-heading font-bold text-lg">01</span>
          </div>
          <h3 class="font-semibold text-primary-900 mb-2 text-sm">Análisis del caso</h3>
          <p class="text-xs text-gray-600 leading-relaxed">Revisamos su documentación médica y, si la tiene, la resolución del centro EVO para entender su situación real.</p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 bg-primary-900 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <span class="text-accent-300 font-heading font-bold text-lg">02</span>
          </div>
          <h3 class="font-semibold text-primary-900 mb-2 text-sm">Estimación orientativa</h3>
          <p class="text-xs text-gray-600 leading-relaxed">Le damos una estimación aproximada del grado que, según los baremos vigentes, podría corresponderle.</p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 bg-primary-900 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <span class="text-accent-300 font-heading font-bold text-lg">03</span>
          </div>
          <h3 class="font-semibold text-primary-900 mb-2 text-sm">Asesoramiento honesto</h3>
          <p class="text-xs text-gray-600 leading-relaxed">Le decimos si, en nuestra opinión, merece la pena reclamar o recurrir. Si vemos pocas posibilidades, se lo decimos igual.</p>
        </div>
      </div>
      <div class="mt-8 text-center">
        <a href={url('/servicios/discapacidad')} class="inline-flex items-center text-sm font-semibold text-primary-700 hover:text-primary-900 transition-colors">
          Ver el servicio completo de discapacidad
          <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 lg:py-20 bg-gray-50/50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-2xl font-bold text-primary-900 mb-8 text-center">Preguntas frecuentes</h2>
      <div class="space-y-3">
        {faqs.map(faq => (
          <details class="group bg-white rounded-xl border border-gray-100 overflow-hidden">
            <summary class="flex justify-between items-center cursor-pointer px-7 py-5 text-primary-900 font-medium hover:bg-gray-50 transition-colors">
              <span class="text-left pr-4 text-sm">{faq.question}</span>
              <svg class="w-5 h-5 text-gray-400 flex-shrink-0 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="px-7 pb-5 text-gray-600 text-sm leading-relaxed">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.question,
      "acceptedAnswer": { "@type": "Answer", "text": f.answer }
    }))
  })} />

  <CTASection title="¿Le han denegado la discapacidad o no está de acuerdo con el grado?" subtitle="Cuéntenos su situación. La valoración es completamente gratuita y le respondemos en menos de 24 horas." />
</Layout>

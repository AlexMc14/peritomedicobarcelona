---
// Botón flotante + modal de contacto. Envía por mailto (sitio estático, sin backend).
---
<button
  id="contact-fab"
  aria-label="Enviar consulta por correo"
  class="fixed bottom-24 right-6 z-50 flex h-14 w-14 items-center justify-center rounded-full bg-primary-900 text-white shadow-lg transition-transform hover:scale-110"
>
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-7 w-7" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
  </svg>
</button>

<dialog id="contact-modal" class="w-full max-w-md rounded-xl p-0 shadow-2xl backdrop:bg-black/50">
  <form id="contact-form" method="dialog" class="p-6">
    <div class="mb-4 flex items-center justify-between">
      <h2 class="text-xl font-bold text-gray-900">Solicita tu consulta</h2>
      <button type="button" id="contact-close" aria-label="Cerrar" class="text-gray-400 hover:text-gray-600 text-2xl leading-none">&times;</button>
    </div>
    <div class="space-y-4">
      <div>
        <label for="cm-nombre" class="mb-1 block text-sm font-medium text-gray-700">Nombre *</label>
        <input id="cm-nombre" name="nombre" required class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:border-primary-900 focus:outline-none" />
      </div>
      <div>
        <label for="cm-telefono" class="mb-1 block text-sm font-medium text-gray-700">Teléfono</label>
        <input id="cm-telefono" name="telefono" type="tel" class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:border-primary-900 focus:outline-none" />
      </div>
      <div>
        <label for="cm-email" class="mb-1 block text-sm font-medium text-gray-700">Email *</label>
        <input id="cm-email" name="email" type="email" required class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:border-primary-900 focus:outline-none" />
      </div>
      <div>
        <label for="cm-mensaje" class="mb-1 block text-sm font-medium text-gray-700">Mensaje *</label>
        <textarea id="cm-mensaje" name="mensaje" required rows="4" class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:border-primary-900 focus:outline-none"></textarea>
      </div>
      <button type="submit" class="w-full rounded-lg bg-primary-900 py-3 font-semibold text-white transition-colors hover:bg-primary-800">
        Enviar consulta
      </button>
    </div>
  </form>
</dialog>

<script>
  const fab = document.getElementById('contact-fab');
  const modal = document.getElementById('contact-modal') as HTMLDialogElement;
  const form = document.getElementById('contact-form') as HTMLFormElement;

  fab?.addEventListener('click', () => modal.showModal());
  document.getElementById('contact-close')?.addEventListener('click', () => modal.close());
  modal?.addEventListener('click', (e) => { if (e.target === modal) modal.close(); });

  form?.addEventListener('submit', () => {
    const d = new FormData(form);
    const body = `Nombre: ${d.get('nombre')}\nTeléfono: ${d.get('telefono') || '-'}\nEmail: ${d.get('email')}\n\n${d.get('mensaje')}`;
    // ponytail: mailto, sin backend; cambiar a Formspree/Resend si hace falta envío server-side
    location.href = `mailto:info@peritomedicobarcelona.com?subject=${encodeURIComponent('Consulta desde la web')}&body=${encodeURIComponent(body)}`;
  });
</script>

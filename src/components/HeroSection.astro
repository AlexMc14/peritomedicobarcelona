---
import { url } from '../utils/links';

interface Props {
  title?: string;
  subtitle?: string;
}
const {
  title = 'Perito Médico en Barcelona',
  subtitle = 'Informes periciales médicos rigurosos para la defensa de sus derechos. Experiencia, independencia y compromiso con cada caso.'
} = Astro.props;
---

<section class="relative bg-primary-950 overflow-hidden">
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.4&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-36">
    <div class="max-w-3xl">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 bg-primary-900/60 border border-primary-700/50 rounded-full px-4 py-1.5 mb-8">
        <span class="w-2 h-2 bg-accent-400 rounded-full animate-pulse"></span>
        <span class="text-xs text-primary-200 font-medium tracking-wide">Peritaje Médico Profesional en Barcelona</span>
      </div>

      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
        {title}
      </h1>

      <p class="text-lg sm:text-xl text-primary-200 leading-relaxed mb-10 max-w-2xl">
        {subtitle}
      </p>

      <div class="flex flex-col sm:flex-row gap-4">
        <a href={url('/contacto')} class="inline-flex items-center justify-center px-8 py-4 bg-accent-500 hover:bg-accent-600 text-white font-semibold rounded-xl transition-all shadow-lg shadow-accent-500/25 hover:shadow-accent-500/40 text-base">
          Solicitar Valoración Gratuita
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
        <a href={url('/servicios/informes-periciales-medicos')} class="inline-flex items-center justify-center px-8 py-4 border-2 border-primary-600 text-white hover:bg-primary-900 font-semibold rounded-xl transition-all text-base">
          Ver Servicios
        </a>
      </div>

      <!-- Trust indicators -->
      <div class="mt-14 flex flex-wrap gap-8 text-sm text-primary-300">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          Independencia total
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          Valoración en 24-48h
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" /></svg>
          Experiencia judicial
        </div>
      </div>
    </div>
  </div>

  <!-- Gradient overlay bottom -->
  <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-white to-transparent"></div>
</section>

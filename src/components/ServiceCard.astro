---
interface Props {
  title: string;
  description: string;
  href: string;
  icon?: string;
}

const { title, description, href } = Astro.props;
---

<a href={href} class="group block bg-white rounded-2xl p-7 border border-gray-100 hover:border-primary-200 hover:shadow-xl hover:shadow-primary-900/5 transition-all duration-300">
  <div class="flex items-start gap-4">
    <div class="w-12 h-12 bg-primary-50 group-hover:bg-primary-100 rounded-xl flex items-center justify-center flex-shrink-0 transition-colors">
      <svg class="w-6 h-6 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
    </div>
    <div class="flex-1">
      <h3 class="font-heading text-lg font-semibold text-primary-900 mb-2 group-hover:text-accent-600 transition-colors">
        {title}
      </h3>
      <p class="text-sm text-gray-500 leading-relaxed">
        {description}
      </p>
      <span class="inline-flex items-center gap-1 mt-4 text-sm font-medium text-primary-700 group-hover:text-accent-600 transition-colors">
        Más información
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
      </span>
    </div>
  </div>
</a>

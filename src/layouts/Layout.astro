---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Perito Médico en Barcelona. Informes periciales médicos, valoración del daño corporal, negligencias médicas e incapacidad laboral. Consulta gratuita.' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="geo.region" content="ES-CT" />
    <meta name="geo.placename" content="Barcelona" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <!-- Schema.org LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "MedicalBusiness",
      "name": "Perito Médico Barcelona",
      "description": description,
      "url": "https://peritomedicobarcelona.com",
      "telephone": "+34 93 000 0000",
      "email": "info@peritomedicobarcelona.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Barcelona",
        "addressLocality": "Barcelona",
        "addressRegion": "Cataluña",
        "postalCode": "08001",
        "addressCountry": "ES"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 41.3851,
        "longitude": 2.1734
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
          "opens": "09:00",
          "closes": "19:00"
        }
      ],
      "areaServed": [
        { "@type": "City", "name": "Barcelona" },
        { "@type": "State", "name": "Cataluña" }
      ],
      "serviceType": [
        "Informes Periciales Médicos",
        "Valoración del Daño Corporal",
        "Negligencia Médica",
        "Incapacidad Laboral",
        "Peritaje Traumatológico",
        "Peritaje Neurológico",
        "Peritaje Psiquiátrico",
        "Accidente de Trabajo",
        "Seguridad Social"
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Servicios de Peritaje Médico",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Valoración gratuita del caso" } }
        ]
      },
      "sameAs": [
        "https://peritomedicobarcelona.com"
      ]
    })} />
  </head>
  <body class="font-body text-gray-800 bg-white antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
</style>
